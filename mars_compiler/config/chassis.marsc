component chassis {
    subcomponents{}
    parameters{
        string type = "tank";
    }
    functions{
        void drive(int dist){
            int location = 0;
            for (int i = 0; i < dist + 1; i++) {
                location++;
            }
            print(location);
        }
        string get_type(){
            print(type);
            return type;
        }

    }
}
