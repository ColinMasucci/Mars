import math;

print(math.sqrt(4^2));
print(math.sqrt(math.abs(5)));
print(math.abs(-42));
print(math.ceil(2.3));
print(math.floor(2.7));
print(math.exp(1));

print(math.log10(1000));

print(math.cos(0));

print(math.asin(1));
print(math.acos(0));
print(math.atan(1));
print(math.atan2(1, 1));
print(math.min_val(3, 1, 4, 1, 5));
print(math.max_val(3, 1, 4, 1, 5));


