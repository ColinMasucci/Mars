int x = 4;
float y = x;

void p(string testName) {
    print(testName + " -     x: " + x + "   y: " + y);
}


print(type(x));
print(type(y));

x += 2;
y += 2;

p("plus");



x -= 1;
y -= 1;

p("minus");

x *= 1.5;
y *= 1.5;

p("mult");


x /= 2;
y /= 2;

p("div");

for (int i = 10; i > 0; i /= 2) {
    print(i);
}

