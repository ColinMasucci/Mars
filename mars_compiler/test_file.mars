int ticks = 0;
int drive_ticks = 10; #drive for 10sec 



while (ticks < drive_ticks) {
    publish("/cmd_vel", "geometry_msgs/msg/Twist", {
        "linear": {"x": 0.0, "y": 0.0, "z": 0.0},
        "angular": {"x": 0.0, "y": 0.0, "z": 0.0}
    });

    wait(1);

    ticks = ticks + 1;
    print(ticks/drive_ticks);
}



publish("/cmd_vel", "geometry_msgs/msg/Twist", {
    "linear": {"x": 0.0, "y": 0.0, "z": 0.0},
    "angular": {"x": 0.0, "y": 0.0, "z": 0.0}
});



print("stopping");

wait(2);

print("stopped");