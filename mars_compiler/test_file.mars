import demo_tools;

int total = demo_tools.add(2, 3);
print("Total: " + total);

string msg = demo_tools.greet("mars");
print("Message: " + msg);

int[] nums = demo_tools.ints();
print("Numbers: " + nums);

dict<string,int> counts = demo_tools.counts();
print("Counts: " + counts);

