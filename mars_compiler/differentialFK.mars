

class DifferentialFK {
    requirements {
        DifferentialChassis;
        
    }

    DifferentialChassis chassis;
    float[] position = [0, 0];

    DifferentialFK(DifferentialChassis chassis){
        this.chassis = chassis;
    }

    void updatePosition(float x, float y) {
        this.position[0] = this.position[0] + x;
        this.position[1] = this.position[1] + y;
    }

    float[] getPosition() {
        return this.position;
    }
    
}
