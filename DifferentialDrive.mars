import Chassis
import Motor

component DifferentialDrive extends Chassis {

subcomponents {
    Motor left_motor;
    Motor right_motor;
}

params {
    float wheel_base;
    float wheel_diameter;
}

functions {
    drive(float left_speed, float right_speed) {
        left_motor.spin(left_speed);
        right_motor.spin(right_speed);
    }
}

}





